# Get a free Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Password to access the app (protects all /dashboard routes)
# Set this to any secret string — never commit the real value
SITE_PASSWORD=your_site_password_here

# Upstash Redis — add the Upstash integration on Vercel to auto-populate these,
# or create a free database at https://console.upstash.com and paste the values here
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
